# Copy to .env.local (never commit .env.local)

# --- FREE AI (recommended — no OpenAI credits needed) ---
# Pick ONE free provider:

# Option 1: Groq — free at https://console.groq.com/keys
AI_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Google Gemini — free at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (paid credits required) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- MongoDB (REQUIRED for multiplayer on Vercel — free tier at https://www.mongodb.com/atlas) ---
# Without this, rooms only live in one server instance → "Room not found" for friends.
# In Atlas: Network Access → allow 0.0.0.0/0 (or Vercel IPs)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=chess_arena

# --- Email invites (all free options below) ---
# Priority: Gmail SMTP → Resend → Email app / Copy link (no env needed)

# Option A: Gmail + nodemailer (free, sends to anyone — REQUIRED for auto-invites)
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → create "Mail" password
# 3. Set GMAIL_USER + GMAIL_APP_PASSWORD on Vercel (Production env)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# Option B: Resend — free tier at https://resend.com
# Test mode: auto-send only to YOUR Resend account email until domain verified.
# After verifying a domain at resend.com/domains, set EMAIL_FROM to e.g. chess@yourdomain.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=AI Chess Arena

# Option C: No email env — use "Email app" or "Copy link" buttons (always free)

# Public URL for invite links (set on Vercel too)
NEXT_PUBLIC_APP_URL=http://localhost:3000
