# Copy to .env.local (never commit .env.local)

# --- FREE AI (recommended — no OpenAI credits needed) ---
# Pick ONE free provider:

# Option 1: Groq — free at https://console.groq.com/keys
AI_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Google Gemini — free at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (paid credits required) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- MongoDB (optional — saves games permanently) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=chess_arena

# --- Email invites (Resend SDK — free tier at https://resend.com) ---
# Test mode: auto-send only works to your Resend account email until you verify a domain.
# After verifying a domain, set EMAIL_FROM to e.g. chess@yourdomain.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=AI Chess Arena
